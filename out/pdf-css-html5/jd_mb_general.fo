                            </fo:block>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_34" chfox:nd-id="préface"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title33"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>Préface</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 8 - <!--content(text)--><fo:inline>Préface</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 8 - <!--content(text)--><fo:inline>Préface</fo:inline></fo:marker><fo:inline>Chapter 8. </fo:inline><fo:inline><fo:inline>Préface</fo:inline></fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le
                                    contenu de ce document vise à faciliter la configuration et le
                                    réglage d'une moissonneuse-batteuse série S en fonction des
                                    conditions, avant la récolte de tournesols.</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Il
                                    présente les composants et les réglages de la machine, en vue
                                    d'améliorer les performances et la qualité de grains dans les
                                    conditions spécifiques au tournesol.</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les réglages et les recommandations de configuration doivent
                                    être considérées comme point de départ. D’autre réglages plus
                                    précis devront être réalisés par la suite en fonction des
                                    conditions et de la teneur en humidité de la récolte.</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">La
                                    partie “Conseils et astuces” vous aidera à réaliser un réglage
                                    de précision de la machine. Le système embarqué de réglage
                                    interactif de la moissonneuse-batteuse, (si équipé) doit
                                    également être utilisé pour obtenir des conseils supplémentaires
                                    de réglage de la part de la machine.</fo:block></fo:block-container>
                            </fo:block></fo:block-container>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_35" chfox:nd-id="réglage-et-inspection-de-la-moissonneuse-batteuse"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title34"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>Réglage et inspection de la moissonneuse-batteuse</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 9 - <!--content(text)--><fo:inline>Réglage et inspection de la moissonneuse-batteuse</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 9 - <!--content(text)--><fo:inline>Réglage et inspection de la moissonneuse-batteuse</fo:inline></fo:marker><fo:inline>Chapter 9. </fo:inline><fo:inline>Réglage et inspection de la
                                    moissonneuse-batteuse</fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                            <fo:block role="Sect" id="unique_36" chfox:nd-id="hauteur-et-vitesse-de-la-chaîne-du-tambour-du-convoyeur-dalimentation">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title35"><fo:block end-indent="0" start-indent="0"><fo:inline>Hauteur et vitesse de la chaîne du
                                        tambour du convoyeur d'alimentation</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Position
                                            du tambour avant – poignée vers le haut pour les
                                            tournesols</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Vitesse du
                                            convoyeur d'alimentation – 26 dents pour les
                                            tournesols.</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/hauteur_convoyeur.png?raw=true" fox:alt-text="hauteur_convoyeur" max-width="100%" scaling="uniform" width="438in div 96" content-width="scale-to-fit" height="172in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_37" chfox:nd-id="vitesse-du-tambour-dalimentation">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title36"><fo:block end-indent="0" start-indent="0"><fo:inline>Vitesse du tambour
                                        d'alimentation</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Basse (550 tr/min)
                                        pour les conditions normales et difficiles. Dans des
                                        conditions sèches et cassantes, la vitesse peut être
                                        abaissée à 320 tr/min en installant le kit BXE10741 (320
                                        tr/min/770 tr/min) Cela permettra de réduire l’endommagement
                                        de la paille et de réduire la charge du caisson. Dans les
                                        conditions sèches, le pignon à 770 tr/min du kit BXE10741
                                        peut ensuite être utilisé pour les petites céréales.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_vitesse_tambour.png" fox:alt-text="Vitesse_tambour" max-width="100%" scaling="uniform" width="380in div 96" content-width="scale-to-fit" height="202in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_38" chfox:nd-id="contre-batteurs">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title37"><fo:block end-indent="0" start-indent="0"><fo:inline>Contre-batteurs</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">3 contre-batteurs
                                        à grand fil nº 2 dans des conditions de battage difficiles.
                                        Dans des conditions de battage faciles, il est également
                                        possible d'utiliser 3 contre-batteurs à barre ronde nº 3. Le
                                        battage ne pose généralement pas de problème pour les
                                        tournesols.</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Se reporter au
                                        livret d'entretien pour la procédure de mise à niveau et le
                                        calibrage à zéro des contre-batteurs (de l'avant à
                                        l'arrière), ainsi que pour l'écartement par rapport aux
                                        éléments de battage.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_contrebatteurs.png" fox:alt-text="Contre-batteurs" max-width="100%" scaling="uniform" width="529in div 96" content-width="scale-to-fit" height="133in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_39" chfox:nd-id="plaques-dobturation-du-contre-batteur">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title38"><fo:block end-indent="0" start-indent="0"><fo:inline>Plaques d'obturation du
                                        contre-batteur</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les plaques
                                        d'obturation du contre-batteur permettent de réduire la
                                        quantité de matière se dirigeant vers le caisson de
                                        nettoyage ou d’influencer la répartition sur le caisson de
                                        nettoyage /vis d’alimentation.</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les plaques
                                        d'obturation du contre-batteur n° 1 (BH84534) pour les
                                        contre batteurs à grand fil permettent de régler avec
                                        précision la distribution sur le caisson de nettoyage. En
                                        cas d'utilisation de contre-batteurs à barre ronde, utiliser
                                        les plaques nº 2 (BH84535).</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_plaque_obturation.png" fox:alt-text="Plaque d'obturation" max-width="100%" scaling="uniform" width="696in div 96" content-width="scale-to-fit" height="245in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_40" chfox:nd-id="grilles-de-séparation">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title39"><fo:block end-indent="0" start-indent="0"><fo:inline>Grilles de séparation</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">S'assurer que les
                                        entretoises de la grille de séparation nº 1 se trouvent sur
                                        le rail pour le tournesol. Cela permettra d’avoir les
                                        grilles en position haute, afin d’assurer un flux constant
                                        de récolte via les organes de battage. Utiliser les
                                        couvercles de grille de séparation nº 2 uniquement lorsque
                                        la répartition au caisson de nettoyage est inégale. Ils
                                        permettent de réduire la quantité de matière sortant du
                                        rotor sur l'extérieur et donc de réduire la charge de
                                        matière au caisson.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_grilles_separation.png" fox:alt-text="Grilles de séparation" max-width="100%" scaling="uniform" width="456in div 96" content-width="scale-to-fit" height="138in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_41" chfox:nd-id="batteur-dotons-et-déflecteurs-supérieurs-réglables-suivant-équipement">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title40"><fo:block end-indent="0" start-indent="0"><fo:inline>Batteur d'otons et déflecteurs
                                        supérieurs réglables (suivant équipement)</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le contre-batteur
                                        du batteur d'otons doit être en position ouverte (maïs).</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_batteur_otons.png" fox:alt-text="Batteur d'otons" max-width="100%" scaling="uniform" width="553in div 96" content-width="scale-to-fit" height="185in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les déflecteurs
                                        supérieurs du rotor doivent être en position standard. Il
                                        est possible de les placer en position avancée uniquement
                                        pour tenter de réduire la quantité de matière sur le caisson
                                        de nettoyage.</fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_42" chfox:nd-id="réglages-des-organes-de-battage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title41"><fo:block end-indent="0" start-indent="0"><fo:inline>Réglages des organes de
                                    battage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le rotor doit être
                                        réglé sur un régime rapide. Régime du rotor – 500 tr/min –
                                        Conditions sèches et cassantes Écartement du contre-batteur
                                        – 30 mm - Conditions de battage sèches et faciles Ces
                                        recommandations de réglages constituent un point de départ
                                        et devront probablement être encore optimisées. Un
                                        écartement de contre-batteur allant jusqu'à 40 mm est
                                        possible dans des conditions de battage faciles.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_reglages_organes_battage.png" fox:alt-text="Capture" max-width="100%" scaling="uniform" width="541in div 96" content-width="scale-to-fit" height="178in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_43" chfox:nd-id="composants-du-caisson-de-nettoyage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title42"><fo:block end-indent="0" start-indent="0"><fo:inline>Composants du caisson de
                                        nettoyage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">La grille à otons
                                        universelle nº 1 et la grille à grain universelle nº 3 sont
                                        couramment utilisées. Il est possible de poser une grille à
                                        otons hautes performances nº 2, qui permet d'obtenir un
                                        échantillon de trémie plus propre et une réduction de la
                                        charge d'otons lorsque que les performances sont limitées
                                        par le caisson de nettoyage</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/composants_caisson_nettoyage.png" fox:alt-text="../media/composants_caisson_nettoyage.png" max-width="100%" scaling="uniform" width="564in div 96" content-width="scale-to-fit" height="134in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les diviseurs des
                                        vis d'alimentation nº 1 doivent être réglés pour obtenir une
                                        répartition uniforme du caisson de nettoyage. Le relevage
                                        des tôles permet de réduire la quantité de matière à
                                        l'extérieur. Il est également possible de poser une
                                        pré-grille à otons réglable nº 2, qui empêche l'accumulation
                                        de tiges dans la grille, lors de la récolte de colza et de
                                        tournesol. Mais l'avantage obtenu dépend fortement des
                                        conditions. L'extension de pré-grille à otons nº 3, n'est
                                        pas livrée avec les machines ZX et ne doit pas être posée
                                        pour le tournesol.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_composants_caisson_nettoyage_2.png" fox:alt-text="../media/S_composants_caisson_nettoyage_2.png" max-width="100%" scaling="uniform" width="666in div 96" content-width="scale-to-fit" height="138in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_44" chfox:nd-id="réglages-du-caisson-de-nettoyage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title43"><fo:block end-indent="0" start-indent="0"><fo:inline>Réglages du caisson de
                                    nettoyage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Ouverture de la
                                        grille à otons – 14 mm – Débit normal L'ouverture de la
                                        grille à otons doit être supérieure de 2 mm en cas de pose
                                        de la grille à otons hautes performances Extension de la
                                        grille à otons – 0 mm – Sur terrain plat ou vallonné
                                        Ouverture de la grille à grain – 5 mm – Débit normal
                                        L'ouverture de la grille à grain doit être supérieure de 1
                                        mm en cas de pose de la grille à otons hautes performances
                                        Régime du ventilateur – 780 tr/min - Débit normal Le régime
                                        du ventilateur doit être optimisé avec une grille à otons
                                        hautes performances. Un régime plus haut du ventilateur est
                                        habituellement nécessaire Suivant équipement, la pré-grille
                                        à otons réglable doit être réglée sur 6mm.</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">L'utilisation du
                                        système Active Terrain Adjustment est très avantageuse, même
                                        sur terrain légèrement vallonné pour obtenir un échantillon
                                        de trémie optimal et gérer le volume d’otons.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/reglage_caisson_nettoyage.png" fox:alt-text="../media/reglage_caisson_nettoyage.png" max-width="100%" scaling="uniform" width="355in div 96" content-width="scale-to-fit" height="133in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_45" chfox:nd-id="transport-du-grain">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title44"><fo:block end-indent="0" start-indent="0"><fo:inline>Transport du grain</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les couvercles de
                                        vis transversale doivent être en position relevée. Le
                                        déflecteur au niveau de la vis de remplissage de la trémie à
                                        grain peut être réglé pour modifier le chargement de la
                                        trémie à grain. La position illustrée permet de charger la
                                        trémie à grain plus à droite.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/transport_grain.png" fox:alt-text="../media/transport_grain.png" max-width="100%" scaling="uniform" width="544in div 96" content-width="scale-to-fit" height="214in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_46" chfox:nd-id="composants-du-système-de-résidus">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title45"><fo:block end-indent="0" start-indent="0"><fo:inline>Composants du système de
                                    résidus</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les palettes
                                        incurvées nº 1 doivent être posées sur chaque deuxième
                                        segment de l’épandeur à disques Advanced PowerCast™. Le
                                        couvercle sous le tambour d'alimentation nº 2 ne doit pas
                                        être posé, car il peut entraîner un enroulement lors de la
                                        récolte de petites céréales. Un ralentisseur de chute nº 3
                                        est disponible pour la configuration Premium afin
                                        d'améliorer la forme des andains et accélérer le séchage de
                                        la paille.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/composants_systeme_residus.png" fox:alt-text="../media/composants_systeme_residus.png" max-width="100%" scaling="uniform" width="656in div 96" content-width="scale-to-fit" height="173in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_47" chfox:nd-id="réglages-des-résidus">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title46"><fo:block end-indent="0" start-indent="0"><fo:inline>Réglages des résidus</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le régime du
                                        broyeur nº 1 doit être réglé sur élevé. Les contre-couteaux
                                        nº 2 doivent être enclenchés uniquement si nécessaire afin
                                        d'éviter toute consommation d'énergie inutile.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/reglages_residus.png" fox:alt-text="../media/reglages_residus.png" max-width="100%" scaling="uniform" width="658in div 96" content-width="scale-to-fit" height="166in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le déflecteur de
                                        rafles nº 1 doit être en position relevée/petites céréales.
                                        Les ailettes du déflecteur arrière ou du volet de
                                        broyage/andainage nº 2 sont réglables afin d'améliorer la
                                        répartition des résidus.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/reglages_residus_deflecteurs.png" fox:alt-text="../media/reglages_residus_deflecteurs.png" max-width="100%" scaling="uniform" width="673in div 96" content-width="scale-to-fit" height="161in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_48" chfox:nd-id="conseils-et-astuces"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title47"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>Conseils et astuces</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 10 - <!--content(text)--><fo:inline>Conseils et astuces</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 10 - <!--content(text)--><fo:inline>Conseils et astuces</fo:inline></fo:marker><fo:inline>Chapter 10. </fo:inline><fo:inline>Conseils et astuces</fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Déterminer l’origine des pertes est essentiel pour prendre les
                                    mesures adéquates (Pertes au niveau de l'unité de récolte, des
                                    organes de battage, du caisson de nettoyage ou des pertes
                                    d‘avant moisson) • S'assurer que la répartition de la matière
                                    est uniforme sur le caisson de nettoyage. C'est primordial. Afin
                                    d'évaluer ceci, effectuer un STOP de la machine pendant la
                                    récolte. Pour équilibrer la répartion, des ajustements peuvent
                                    être réalisés au niveau des diviseurs des vis d'alimentation et
                                    des couvercles peuvent être installés sur les grilles de
                                    separation du contrebatteur. • Si les performances de la
                                    moissonneuse-batteuse sont limitées dû à un caisson de nettoyage
                                    trop chargé et qu'il est souhaitable d'améliorer la qualité du
                                    grain en trémie tout en évitant d'augmenter les pertes ou de
                                    surcharger le système d’otons, il faut tenter de modifier les
                                    réglages de la moissonneuse-batteuse pour diminuer la quantité
                                    de matière se dirigeant vers le caisson de nettoyage. Par
                                    exemple en réduisant le régime du rotor, en ouvrant d’avantage
                                    le contre-batteur ou en posant des plaques d’obturation. Veillez
                                    également à maintenir une distribution à peu près régulière sur
                                    le caisson de nettoyage. 11 • Modifier légèrement, par
                                    incréments, le réglage de la grille à grain, de la grille à
                                    otons et du ventilateur pour atteindre la valeur optimale. • Le
                                    type de culture et les conditions ont une influence considérable
                                    sur la productivité et les réglages de la machine. Bien les
                                    évaluer avant de commencer la récolte. En conditions sèches, il
                                    est particulièrement important de couper le plus haut possible
                                    pour réduire la quantité de paille dans la machine. • Tenter de
                                    maintenir un débit de récolte et de remplissage de la machine
                                    réguliers lors du fonctionnement. Cela permet d'augmenter les
                                    performances du caisson de nettoyage et de la machine étant
                                    donné que les réglages sont optimisés pour ce débit. • Les
                                    réglages fais en cabines sont précis uniquement si les
                                    calibrations sont correctes. Contrôler fréquemment que les
                                    “valeurs cabines” correspondent bien aux valeurs réelles (ex:
                                    ouverture grille otons…)</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123314.png" fox:alt-text="../media/Capture%20d%27%C3%A9cran%202026-02-02%20123314.png" max-width="100%" scaling="uniform" width="608in div 96" content-width="scale-to-fit" height="197in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline>
                                    <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123403.png" fox:alt-text="../media/Capture%20d%27%C3%A9cran%202026-02-02%20123403.png" max-width="100%" scaling="uniform" width="591in div 96" content-width="scale-to-fit" height="225in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline>
                                    <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123409.png" fox:alt-text="../media/Capture%20d%27%C3%A9cran%202026-02-02%20123409.png" max-width="100%" scaling="uniform" width="598in div 96" content-width="scale-to-fit" height="227in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container>
                            </fo:block></fo:block-container>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" id="last-page-sequence" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_49" chfox:nd-id="outils-et-liens"><fo:block end-indent="0" start-indent="0">
