                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_1" chfox:nd-id="réglage-et-inspection"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title1"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>Réglage et inspection</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 1 - <!--content(text)--><fo:inline>Réglage et inspection</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 1 - <!--content(text)--><fo:inline>Réglage et inspection</fo:inline></fo:marker><fo:inline>Chapter 1. </fo:inline><fo:inline>Réglage et inspection</fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                            <fo:block role="Sect" id="unique_2" chfox:nd-id="nettoyage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title2"><fo:block end-indent="0" start-indent="0"><fo:inline>Nettoyage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                                <fo:block role="Sect" id="unique_3" chfox:nd-id="tambour-du-convoyeur-dalimentation">
                                    <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H3" id="ariaid-title3"><fo:block end-indent="0" start-indent="0"><fo:inline>Tambour du convoyeur
                                            d'alimentation</fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                                    <fo:block role="Sect" id="unique_4" chfox:nd-id="hauteur-vitesse-et-position">
                                        <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H4" id="ariaid-title4"><fo:block end-indent="0" start-indent="0"><fo:inline>Hauteur, vitesse et
                                                position</fo:inline></fo:block></fo:block-container>
                                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                            <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Position du tambour avant : Poignée vers le
                                                  bas</fo:block></fo:list-item-body></fo:list-item>
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Vitesse de la chaîne du convoyeur : 32 dents pour
                                                  les conditions de récolte de blé normales et
                                                  difficiles, 26 dents dans des conditions sèches.
                                                  <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_hauteur_convoyeur.png" fox:alt-text="Photo du réglage sur la machine" max-width="100%" scaling="uniform" width="438in div 96" content-width="scale-to-fit" height="172in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:list-item-body></fo:list-item>
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Vitesse rapide par défaut. Par temps sec,
                                                  abaisser la vitesse pour réduire l’endommagement
                                                  de la paille et de réduire la charge du caisson.
                                                  <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_vitesse_tambour.png" fox:alt-text="Photo du réglage sur la machine" max-width="100%" scaling="uniform" width="380in div 96" content-width="scale-to-fit" height="202in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:list-item-body></fo:list-item>
                                            </fo:list-block>
                                        </fo:block></fo:block-container>
                                    </fo:block>
                                </fo:block>
                            </fo:block>
                            <fo:block role="Sect" id="unique_5" chfox:nd-id="battage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title5"><fo:block end-indent="0" start-indent="0"><fo:inline>Battage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                                <fo:block role="Sect" id="unique_6" chfox:nd-id="battage-et-séparation">
                                    <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H3" id="ariaid-title6"><fo:block end-indent="0" start-indent="0"><fo:inline>Battage et séparation</fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container>
                                    <fo:block role="Sect" id="unique_7" chfox:nd-id="contre-batteurs">
                                        <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H4" id="ariaid-title7"><fo:block end-indent="0" start-indent="0"><fo:inline>Contre-batteurs</fo:inline></fo:block></fo:block-container>
                                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Il est
                                                recommandé d'utiliser les contre-batteurs à petit
                                                fil nº 1 et à gros fil nº 2 pour les céréales. Ils
                                                offrent les meilleures performances.</fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Configuration standard de la machine :</fo:block></fo:block-container>
                                            <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Avant : Contre-batteur à petit fil</fo:block></fo:list-item-body></fo:list-item>
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Milieu : Contre-batteur à petit fil</fo:block></fo:list-item-body></fo:list-item>
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Arrière : Contre-batteur à grand fil</fo:block></fo:list-item-body></fo:list-item>
                                            </fo:list-block>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Conditions
                                                de battage difficiles :</fo:block></fo:block-container>
                                            <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Remplacez le contre-batteur du milieu par un
                                                  contre-batteur à grand fil.</fo:block></fo:list-item-body></fo:list-item>
                                            </fo:list-block>
                                            <fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Cela
                                                  augmente le
                                                battage.</fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container>
                                            <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                                <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Remarque : Les contre-batteurs à mini barre ronde
                                                  nº 3 doivent uniquement être utilisés dans des
                                                  conditions difficiles lors de bourrages de
                                                  contre-batteur, et lorsque les réglages machines
                                                  ne suffisent plus.</fo:block></fo:list-item-body></fo:list-item>
                                            </fo:list-block>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Reportez-vous au livret d'entretien pour la
                                                procédure de mise à niveau et le calibrage à zéro
                                                des contre-batteurs (de l'avant à l'arrière), ainsi
                                                que pour l'écartement par rapport aux éléments de
                                                battage. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_contrebatteurs.png" fox:alt-text="Les trois différents contre-batteurs" max-width="100%" scaling="uniform" width="529in div 96" content-width="scale-to-fit" height="133in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                    </fo:block>
                                    <fo:block role="Sect" id="unique_8" chfox:nd-id="plaques-dobturation">
                                        <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H4" id="ariaid-title8"><fo:block end-indent="0" start-indent="0"><fo:inline>Plaques
                                            d'obturation</fo:inline></fo:block></fo:block-container>
                                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Généralement pas nécessaire grace aux performances
                                                de battage élevées du contre batteur à petit fil et
                                                du rotor.</fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Si le
                                                battage est insuffisant, installez les plaques dans
                                                l'ordre suivant, pour optimiser le traitement des
                                                otons :</fo:block></fo:block-container>
                                            <fo:block>
                                                <fo:table-and-caption border-collapse="collapse" space-before="1em" space-after="1em"><fo:table-caption start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container page-break-after="avoid" font-weight="bold" space-before="0.5em" text-align="center"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:table-caption><fo:table relative-align="baseline" chfox:html-table-width-policy="yes" table-layout="auto" hyphenate="true" space-before="0" space-after="0"><fo:table-column/><fo:table-column/><fo:table-header font-weight="bold" text-align="center" display-align="center">
                                                  <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" id="unique_8__entry__1"><fo:block>Modèles de machine</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" id="unique_8__entry__2"><fo:block>Ordre de pose</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  </fo:table-header><fo:table-body display-align="center">
                                                  <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" display-align="before"><fo:block><fo:inline font-weight="bold">S660
                                                  et S670</fo:inline></fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" display-align="before"><fo:block>1 → 4 → 5 → 2 → 3</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" display-align="before"><fo:block><fo:inline font-weight="bold">S680 à
                                                  S690</fo:inline></fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="left" display-align="before"><fo:block>1 → 2 → 3 → 4 → 5</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  </fo:table-body></fo:table></fo:table-and-caption>
                                            </fo:block>
                                            <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_plaque_obturation.png" fox:alt-text="Une plaque d'obturation placée sur un contre-batteur" max-width="100%" scaling="uniform" width="696in div 96" content-width="scale-to-fit" height="245in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                    </fo:block>
                                    <fo:block role="Sect" id="unique_9" chfox:nd-id="grilles-de-séparation">
                                        <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H4" id="ariaid-title9"><fo:block end-indent="0" start-indent="0"><fo:inline>Grilles de
                                            séparation</fo:inline></fo:block></fo:block-container>
                                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les
                                                entretoises de la grille de séparation nº 1 doivent
                                                se trouver sur le rail pour l'orge. Cela permet
                                                d’avoir les grilles en position haute et d’assurer
                                                un flux constant de récolte via les organes de
                                                battage.</fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block role="Sect" id="unique_10" chfox:nd-id="en-cas-de-mauvaise-répartition-au-caisson-de-nettoyage">
                                            <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H5" id="ariaid-title10"><fo:block end-indent="0" start-indent="0"><fo:inline>En cas de mauvaise
                                                  répartition au caisson de nettoyage</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Utilisez
                                                  les couvercles de grille de séparation nº 2. Ils
                                                  limitent la sortie de matière par l'extérieur du
                                                  rotor.</fo:block></fo:block-container>
                                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Avant
                                                  d'installer les couvercles :</fo:inline> Tentez
                                                  d'abord d'équilibrer la répartition en réglant les
                                                  diviseurs des vis d'alimentation. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_grilles_separation.png" fox:alt-text="Les différentes grilles de séparation" max-width="100%" scaling="uniform" width="456in div 96" content-width="scale-to-fit" height="138in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container>
                                            </fo:block></fo:block-container>
                                        </fo:block>
                                    </fo:block>
                                    <fo:block role="Sect" id="unique_11" chfox:nd-id="batteur-dotons-et-déflecteurs-supérieurs-réglables-suivant-équipement">
                                        <fo:block-container page-break-after="avoid" font-size="1.4em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H4" id="ariaid-title11"><fo:block end-indent="0" start-indent="0"><fo:inline>Batteur d'otons et déflecteurs
                                                supérieurs réglables (suivant
                                            équipement)</fo:inline></fo:block></fo:block-container>
                                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le
                                                contre-batteur du batteur d'otons doit être en
                                                position fermée.</fo:block></fo:block-container>
                                            <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Documents/M2%20TI/S2/r%C3%A9dac%20collaborative/JD%202026/John-Deere2026/media/S_batteur_otons.png" fox:alt-text="Le contre-batteur d'otons en photo et vue 3D" max-width="100%" scaling="uniform" width="553in div 96" content-width="scale-to-fit" height="185in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
