                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Placer les
                                            entretoises de la grille nº 1 sur le rail tournesol pour
                                            maintenir les grilles en position haute et assurer un
                                            flux constant.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Utiliser
                                            les couvercles de la grille nº 2 uniquement si la
                                            répartition au caisson est inégale, afin de limiter le
                                            flux vers l’extérieur et réduire la charge.</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                </fo:block></fo:block-container>
                            </fo:block>
