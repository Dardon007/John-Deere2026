                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title15"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>&lt;&lt;&lt;&lt;&lt;&lt;&lt; Updated upstream</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 8 - <!--content(text)--><fo:inline>&lt;&lt;&lt;&lt;&lt;&lt;&lt; Updated upstream</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 8 - <!--content(text)--><fo:inline>&lt;&lt;&lt;&lt;&lt;&lt;&lt; Updated upstream</fo:inline></fo:marker><fo:inline>Chapter 8. </fo:inline><fo:inline>&lt;&lt;&lt;&lt;&lt;&lt;&lt; Updated
                                    upstream <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_batteur_otons.png? file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_batteur_otons.png?raw=true" fox:alt-text="Batteur d'otons" max-width="100%" scaling="uniform" width="553in div 96" content-width="scale-to-fit" height="185in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_batteur_otons.png? file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_batteur_otons.png?raw=true" fox:alt-text="image batteur d'otons" max-width="100%" scaling="uniform" width="553in div 96" content-width="scale-to-fit" height="185in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                <fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Stashed
                                                  changes</fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les déflecteurs supérieurs du rotor doivent être en position
                                    standard. Il est possible de les placer en position avancée
                                    uniquement pour tenter de réduire la quantité de matière sur le
                                    caisson de nettoyage.</fo:block></fo:block-container>
                            </fo:block></fo:block-container>
                            <fo:block role="Sect" id="unique_18" chfox:nd-id="26-réglages-des-organes-de-battage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title16"><fo:block end-indent="0" start-indent="0"><fo:inline>2.6. Réglages des organes de
                                        battage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Le rotor doit être
                                        réglé sur un régime rapide.</fo:block></fo:block-container>
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Conditions
                                            sèches et cassantes : Régime du rotor – 500 tr/min.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Conditions
                                            de battage sèches et faciles : Écartement du
                                            contre-batteur – 30 mm.</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Note :</fo:inline> Ces
                                        recommandations de réglages constituent un point de départ
                                        et devront probablement être encore optimisées. Un
                                        écartement de contre-batteur allant jusqu'à 40 mm est
                                        possible dans des conditions de battage faciles.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_reglages_organes_battage.png" fox:alt-text="image organe battage" max-width="100%" scaling="uniform" width="541in div 96" content-width="scale-to-fit" height="178in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_19" chfox:nd-id="27-composants-et-réglages-du-caisson-de-nettoyage">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title17"><fo:block end-indent="0" start-indent="0"><fo:inline>2.7. Composants et réglages du caisson
                                        de nettoyage</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les grilles
                                        universelles nº 1 et nº 3 sont les plus utilisées. La grille
                                        nº 2 haute performance améliore la propreté de l’échantillon
                                        et réduit la charge d’otons quand le caisson limite les
                                        performances. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/composants_caisson_nettoyage.png" fox:alt-text="image grille" max-width="100%" scaling="uniform" width="564in div 96" content-width="scale-to-fit" height="134in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container>
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Régler les
                                            diviseurs des vis nº 1 pour une répartition
                                            uniforme.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Relever
                                            les tôles pour limiter le flux vers l’extérieur.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">3. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Optionnel
                                            : La pré-grille réglable nº 2 peut réduire
                                            l’accumulation de tiges (selon conditions).</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Avertissement</fo:inline> : Ne
                                            pas utiliser l’extension nº 3 pour le tournesol. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/S_composants_caisson_nettoyage_2.png" fox:alt-text="image reglage grilles" max-width="100%" scaling="uniform" width="666in div 96" content-width="scale-to-fit" height="138in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container>
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Ouverture
                                            grille à otons : 14 mm (débit normal), +2 mm avec grille
                                            haute performance.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Extension
                                            : 0 mm (terrain plat/vallonné).</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Ouverture
                                            grille à grain : 5 mm (débit normal), +1 mm avec grille
                                            haute performance.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Ventilateur : 780 tr/min (débit normal), à augmenter
                                            avec grille haute performance.</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">• </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Pré-grille
                                            réglable : 6 mm (selon équipement).</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Note</fo:inline> : L'utilisation
                                            du système Active Terrain Adjustment est très
                                            avantageuse, même sur terrain légèrement vallonné pour
                                            obtenir un échantillon de trémie optimal et gérer le
                                            volume
                                        d’otons.</fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/reglage_caisson_nettoyage.png" fox:alt-text="image reglages caisson" max-width="100%" scaling="uniform" width="355in div 96" content-width="scale-to-fit" height="133in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_20" chfox:nd-id="28-transport-du-grain">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title18"><fo:block end-indent="0" start-indent="0"><fo:inline>2.8 Transport du grain</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Les couvercles de
                                        vis transversale doivent être en position relevée. Le
                                        déflecteur au niveau de la vis de remplissage de la trémie à
                                        grain peut être réglé pour modifier le chargement de la
                                        trémie à grain. La position illustrée permet de charger la
                                        trémie à grain plus à droite.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/transport_grain.png" fox:alt-text="../media/transport_grain.png" max-width="100%" scaling="uniform" width="544in div 96" content-width="scale-to-fit" height="214in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_21" chfox:nd-id="29-réglages-des-composants-du-système-de-résidus">
                                <fo:block-container page-break-after="avoid" font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" role="H2" id="ariaid-title19"><fo:block end-indent="0" start-indent="0"><fo:inline>2.9. Réglages des composants du système
                                        de résidus</fo:inline></fo:block></fo:block-container>
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Monter les
                                            palettes incurvées nº 1 un segment sur deux sur
                                            l’épandeur Advanced PowerCast™.</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container border-left-color="rgb(238 , 238 , 238)" border-left-style="solid" border-left-width="2px" space-after="1em" margin-left="40px" margin-right="40px" space-before="1em" padding-left="0.5em"><fo:block end-indent="0" start-indent="0"><fo:inline font-size="1.2em">“</fo:inline><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Avertissement</fo:inline> : Ne
                                            pas installer le couvercle nº 2 sous le tambour
                                            d’alimentation (risque d’enroulement en petites
                                            céréales).</fo:block></fo:block-container><fo:inline font-size="1.2em">”</fo:inline></fo:block></fo:block-container>
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Optionnel
                                                : Installer le ralentisseur de chute nº 3 (version
                                                Premium) pour améliorer la forme des andains et
                                                accélère le séchage. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/composants_systeme_residus.png" fox:alt-text="images systeme residus" max-width="100%" scaling="uniform" width="656in div 96" content-width="scale-to-fit" height="173in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:block-container>
                                        </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Régler le
                                                régime du broyeur nº 1 sur élevé.</fo:block></fo:block-container>
                                        </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">3. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Enclencher
                                                les contre-couteaux nº 2 uniquement si nécessaire
                                                pour limiter la consommation d’énergie.</fo:block></fo:block-container>
                                        </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/reglages_residus.png" fox:alt-text="image broyeur et contre-couteaux" max-width="100%" scaling="uniform" width="658in div 96" content-width="scale-to-fit" height="166in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                    <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Mettre le
                                            déflecteur de rafles nº 1 en position relevée (petites
                                            céréales).</fo:block></fo:list-item-body></fo:list-item>
                                        <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Régler les
                                            ailettes du déflecteur arrière ou du volet nº 2 pour
                                            optimiser la répartition des résidus.</fo:block></fo:list-item-body></fo:list-item>
                                    </fo:list-block>
                                    <fo:block-container space-after="1em" max-width="100%"><fo:block end-indent="0" start-indent="0"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/reglages_residus_deflecteurs.png" fox:alt-text="image deflecteur et ailettes" max-width="100%" scaling="uniform" width="673in div 96" content-width="scale-to-fit" height="161in div 96" content-height="scale-to-fit"/></fo:inline></fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" role="Sect" id="unique_5" chfox:nd-id="3-conseils-et-astuces"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container page-break-after="avoid" font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" role="H1" id="ariaid-title20"><fo:block end-indent="0" start-indent="0"><fo:marker marker-class-name="chaptertitle-only"><fo:inline/> <!--content(text)--><fo:inline>3. Conseils et astuces</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 9 - <!--content(text)--><fo:inline>3. Conseils et astuces</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 9 - <!--content(text)--><fo:inline>3. Conseils et astuces</fo:inline></fo:marker><fo:inline>Chapter 9. </fo:inline><fo:inline>3. Conseils et astuces</fo:inline></fo:block></fo:block-container>
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Identifier la
                                        source des pertes (unité de récolte, battage, nettoyage ou
                                        avant moisson).</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Assurer une
                                        répartition homogène sur le caisson de nettoyage (STOP
                                        machine pour contrôle) et ajuster si besoin les diviseurs
                                        des vis d’alimentation et les couvercles du
                                        contre-batteur.</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">3. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Si le caisson
                                        est trop chargé, réduire la matière envoyée (régime rotor
                                        plus faible, ouverture contre-batteur plus grande, plaques
                                        d’obturation) tout en maintenant une répartition
                                        régulière.</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">4. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Ajuster
                                        progressivement grille à grain, grille à otons et
                                        ventilateur pour optimiser les réglages.</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">5. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Adapter les
                                        réglages aux conditions de culture (couper haut en
                                        conditions sèches).</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">6. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Maintenir un
                                        débit régulier pour stabiliser les performances.</fo:block></fo:list-item-body></fo:list-item>
                                    <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">7. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Vérifier
                                        régulièrement la concordance entre réglages cabine et
                                        valeurs réelles. <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123314.png" fox:alt-text="image de moissonneuse-batteuse" max-width="100%" scaling="uniform" width="608in div 96" content-width="scale-to-fit" height="197in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline>
                                        <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123403.png" fox:alt-text="image de moissonneuse-batteuse" max-width="100%" scaling="uniform" width="591in div 96" content-width="scale-to-fit" height="225in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline>
                                        <fo:inline chfox:inch="true" max-width="100%"><fo:inline><fo:external-graphic src="file:/C:/Users/Charl%C3%A8ne/Pictures/John-Deere2026/media/Capture%20d'%C3%A9cran%202026-02-02%20123409.png" fox:alt-text="image de moissonneuse-batteuse" max-width="100%" scaling="uniform" width="598in div 96" content-width="scale-to-fit" height="227in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline></fo:block></fo:list-item-body></fo:list-item>
                                </fo:list-block>
                            </fo:block></fo:block-container>
                        </fo:block></fo:block-container>
                        </fo:block></fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container></fo:block></fo:flow></fo:page-sequence><fo:page-sequence master-reference="chapter" force-page-count="no-force" id="last-page-sequence" line-height-shift-adjustment="disregard-shifts"><fo:static-content flow-name="sc-before-left" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-LEFT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="left" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="sc-before-right" role="artifact"><fo:table border-collapse="separate" table-layout="fixed" width="100%"><fo:table-body><fo:table-row><!--TOP-RIGHT--><fo:table-cell start-indent="0" end-indent="0" height="1in" width="(8.5in - 1in - 1in)" text-align="right" display-align="center" font-size="10pt" font-family="Roboto , sans-serif"><fo:block><fo:retrieve-marker retrieve-class-name="maptitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="parttitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="chaptertitle" 